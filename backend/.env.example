# Copy this file to .env and fill in real values
# .env is gitignored and should NEVER be committed

# --- Server ---
PORT=5000

# --- JWT ---
# Use a long random string, e.g.: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# --- Doctor Registration Secret ---
# Doctors need this invite code to register
DOCTOR_SECRET=CHANGE_ME_DOCTOR_INVITE_CODE

# --- Gemini AI ---
# Get your key from: https://aistudio.google.com/apikey
# Primary key (Account 1)
GEMINI_API_KEY=your_gemini_api_key_here
# Secondary key (Account 2) - used as fallback when primary hits rate limit (14 req/min)
# Leave empty if you only have one account
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# --- CORS ---
# Frontend origin (no trailing slash)
# e.g. http://localhost:5173 for local dev
ALLOWED_ORIGIN=http://localhost:5173

# --- Admin System ---
# First admin created automatically on startup if none exists in the DB
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
